{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "installCommand": "npm install",
  "outputDirectory": "apps/web/.next",
  "devCommand": "npm run dev",
  "functions": {
    "apps/web/.next/server/app/**/*.js": {
      "maxDuration": 60
    }
  },
  "rewrites": [
    { "source": "/_/auth/(.*)", "destination": "/api/auth/$1" },
    { "source": "/_/design/(.*)", "destination": "/api/design/$1" },
    { "source": "/_/video/(.*)", "destination": "/api/video/$1" },
    { "source": "/(.*)", "dest": "apps/web/$1" }
  ]
}