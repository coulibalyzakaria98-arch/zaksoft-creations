generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model UsageEvent {
  id            String         @id @default(cuid())
  userId        String
  teamId        String?
  service       ServiceType
  operation     String
  cost          Float
  credits       Int
  duration      Int
  status        String
  metadata      Json?
  ipAddress     String?
  userAgent     String?
  createdAt     DateTime       @default(now())
  
  @@index([userId, createdAt])
  @@index([teamId, createdAt])
  @@index([service, createdAt])
  @@index([createdAt])
}

model DailyUsage {
  id            String         @id @default(cuid())
  userId        String
  teamId        String?
  date          DateTime
  service       ServiceType
  operations    Int
  totalCost     Float
  totalCredits  Int
  avgDuration   Float
  createdAt     DateTime       @default(now())
  
  @@unique([userId, date, service])
  @@index([userId, date])
  @@index([teamId, date])
}

enum ServiceType {
  DESIGN
  VIDEO
  WEB
  TEAMS
  MARKETPLACE
  DEPLOYMENT
}
